[tltest.sequence]
mode.0                      = FUZZ_STREAM_GS
mode.1                      = FUZZ_STREAM_GS

[tltest.profile]
cycle_unit                  = 2

[tltest.fuzzer]
seed                        = 1000
ari.interval                = 10000
ari.target                  = 18
stream.interval             = 100
stream.step                 = 0x40
stream.start                = 0x00000000
stream.end                  = 0x00080000 # ~0x0007FFFF

[tltest.logger]
verbose                     = 0
verbose.xact_fired          = 1
verbose.xact_sequenced      = 0
verbose.xact_data_complete  = 1
verbose.memory.axi_write    = 1
verbose.memory.axi_read     = 1
verbose.data_full           = 0
verbose.agent_debug         = 0

# coupledL2-test-l2l3
[tltest.config]
core                        = 1
core.tl_c                   = 1
core.tl_ul                  = 1
core.tl_m                   = 8
# core.tl_lv                   = 8

[tltest.sequence]
# MAgent id starting from 2
mode.2                      = TRACE_WITH_FENCE
